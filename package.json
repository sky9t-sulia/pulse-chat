{
  "name": "chat-app",
  "version": "1.0.0",
  "private": true,
  "description": "A local first LLM desktop app",
  "author": "suleiman <suleiman@example.com>",
  "homepage": "https://github.com/suleiman/chat-app",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build:web": "tsc -p tsconfig.json && vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.electron.json && vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && tsc -p tsconfig.electron.json && electron dist-electron/main.js\"",
    "electron:build": "tsc -p tsconfig.json && tsc -p tsconfig.electron.json && vite build && electron-builder",
    "build:release": "tsc -p tsconfig.json && tsc -p tsconfig.electron.json && vite build && electron-builder --linux AppImage",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "lucide-react": "^0.460.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "react-syntax-highlighter": "^15.6.1",
    "remark-gfm": "^4.0.0",
    "sql.js": "^1.12.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/prismjs": "^1.26.5",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/sql.js": "^1.4.9",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vite": "^6.0.3",
    "vite-plugin-electron": "^0.28.8",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.chat.app",
    "productName": "Chat App",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": "AppImage",
      "category": "Utility",
      "icon": "icon.png"
    }
  }
}
